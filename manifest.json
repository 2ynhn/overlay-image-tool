{
  "manifest_version": 3,
  "name": "Overlay Image Tool",
  "version": "1.4",  
  "description": "Overlay design drafts on your web pages to compare and verify UI implementation accuracy.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts" : [{
	"matches" : ["<all_urls>"],
	"js" : ["content.js"]
  }],
  "action": {
    "default_popup": "popup.html",
	"default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  }
}