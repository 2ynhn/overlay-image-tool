{
  "manifest_version": 3,
  "name": "Overlay Image Tool",
  "version": "1.4",
  "description": "Overlay your design draft on any page to compare with the actual UI.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  }
}